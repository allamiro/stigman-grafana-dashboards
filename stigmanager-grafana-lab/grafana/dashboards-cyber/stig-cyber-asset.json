            "uid": "stigmanager-infinity"
          },
          "queryType": "infinity",
          "type": "json",
          "source": "url",
          "format": "table",
          "parser": "backend",
          "url": "http://stigman:54000/api/collections/$collection/metrics/summary/asset",
          "url_options": {
            "method": "GET",
            "data": ""
          },
          "root_selector": "",
          "columns": [
            {
              "selector": "assetId",
              "text": "assetId",
              "type": "string"
            },
            {
              "selector": "metrics.assessments",
              "text": "assessments",
              "type": "number"
            },
            {
              "selector": "metrics.assessed",
              "text": "assessed",
              "type": "number"
            }
          ],
          "computed_columns": [
            {
              "selector": "assessments > 0 ? assessed / assessments * 100 : 0",
              "text": "Coverage",
              "type": "number"
            }
          ],
          "filterExpression": "assetId IN ('$asset')"
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
