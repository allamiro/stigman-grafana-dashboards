    {
      "type": "gauge",
      "title": "CORA risk (this asset)",
      "description": "CORA-style weighted risk score computed from aggregated raw counts: p_sev = (open findings + unassessed) / assessments per severity, CORA = (p1*10 + p2*4 + p3*1) / 15. Zero-assessment severities contribute 0. Bands: 0% Low, >0% Moderate, >=10% High, >=20% Very High. Lab interpretation \u2014 verify against current DISA CORA guidance before treating as authoritative.",
      "gridPos": {
        "h": 5,
        "w": 5,
        "x": 14,
        "y": 0
      },
      "datasource": {
        "type": "yesoreyeram-infinity-datasource",
        "uid": "stigmanager-infinity"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "yesoreyeram-infinity-datasource",
            "uid": "stigmanager-infinity"
          },
          "queryType": "infinity",
          "type": "json",
          "source": "url",
          "format": "table",
          "parser": "backend",
          "url": "http://stigman:54000/api/collections/$collection/metrics/summary/asset",
          "url_options": {
            "method": "GET",
            "data": ""
          },
          "root_selector": "",
          "columns": [
            {
              "selector": "assetId",
              "text": "assetId",
              "type": "string"
            },
            {
              "selector": "metrics.findings.high",
              "text": "high",
              "type": "number"
            },
            {
              "selector": "metrics.findings.medium",
              "text": "medium",
              "type": "number"
            },
            {
              "selector": "metrics.findings.low",
              "text": "low",
              "type": "number"
            },
            {
              "selector": "metrics.assessmentsBySeverity.high",
              "text": "assessmentsHigh",
              "type": "number"
            },
            {
              "selector": "metrics.assessmentsBySeverity.medium",
              "text": "assessmentsMedium",
              "type": "number"
            },
            {
              "selector": "metrics.assessmentsBySeverity.low",
              "text": "assessmentsLow",
              "type": "number"
            },
            {
              "selector": "metrics.assessedBySeverity.high",
              "text": "assessedHigh",
              "type": "number"
            },
            {
              "selector": "metrics.assessedBySeverity.medium",
              "text": "assessedMedium",
              "type": "number"
            },
            {
              "selector": "metrics.assessedBySeverity.low",
              "text": "assessedLow",
              "type": "number"
            }
          ],
          "computed_columns": [
            {
              "selector": "((assessmentsHigh > 0 ? (high + assessmentsHigh - assessedHigh) / assessmentsHigh : 0) * 10 + (assessmentsMedium > 0 ? (medium + assessmentsMedium - assessedMedium) / assessmentsMedium : 0) * 4 + (assessmentsLow > 0 ? (low + assessmentsLow - assessedLow) / assessmentsLow : 0) * 1) / 15 * 100",
              "text": "CORA",
              "type": "number"
            }
          ],
          "filterExpression": "assetId IN ('$asset')"
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ]
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "minVizHeight": 75,
        "minVizWidth": 75,
        "sizing": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "#EAB839",
                "value": 0.001
              },
              {
                "color": "orange",
                "value": 10
              },
              {
                "color": "red",
                "value": 20
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "transformations": [
        {
          "id": "filterFieldsByName",
          "options": {
            "include": {
              "names": [
                "CORA"
              ]
            }
          }
        }
      ],
      "id": 3
    },
