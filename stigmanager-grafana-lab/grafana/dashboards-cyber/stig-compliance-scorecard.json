      "datasource": {
        "type": "prometheus",
        "uid": "stigmanager-prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "stigmanager-prometheus"
          },
          "expr": "stigman_collection_assessed{collection_name=~\"${collection:text}\"} / clamp_min(stigman_collection_assessments{collection_name=~\"${collection:text}\"}, 1) * 100",
