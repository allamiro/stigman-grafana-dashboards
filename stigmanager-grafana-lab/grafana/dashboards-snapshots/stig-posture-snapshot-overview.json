    "stig",
    "posture",
    "snapshot"
  ],
  "timezone": "browser",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "liveNow": false,
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5m",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "collection",
        "label": "Collections",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "stigmanager-prometheus"
