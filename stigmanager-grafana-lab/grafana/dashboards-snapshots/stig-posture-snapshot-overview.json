  "panels": [
    {
      "type": "text",
      "title": "",
      "gridPos": {
        "h": 4,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "options": {
        "mode": "markdown",
        "code": {
          "language": "plaintext",
          "showLineNumbers": false,
          "showMiniMap": false
        },
        "content": "# Security Compliance \u2014 Review Snapshot (from recorded history)\nFamiliar review visuals (pies, bars, stats) backed by **recorded history** \u2014 no graphs to watch.\n**How the time picker works here:** every panel shows posture **as of the END of the selected time range**. Leave it at *now* for the current review; set the range to end on a past date (e.g. *yesterday 17:00*) and the whole page shows posture as it was then. History exists from the first exporter run onward.\n"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "id": 1
    },
    {
      "type": "stat",
      "title": "Bottom line",
      "description": "CORA-style weighted risk verdict as of the selected point in time.",
      "gridPos": {
        "h": 6,
        "w": 7,
        "x": 0,
        "y": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "stigmanager-prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "stigmanager-prometheus"
          },
          "expr": "(((sum(stigman_collection_findings{severity=\"high\"}) + sum(stigman_collection_assessments_by_severity{severity=\"high\"}) - sum(stigman_collection_assessed_by_severity{severity=\"high\"})) / clamp_min(sum(stigman_collection_assessments_by_severity{severity=\"high\"}), 1)) * 10 + ((sum(stigman_collection_findings{severity=\"medium\"}) + sum(stigman_collection_assessments_by_severity{severity=\"medium\"}) - sum(stigman_collection_assessed_by_severity{severity=\"medium\"})) / clamp_min(sum(stigman_collection_assessments_by_severity{severity=\"medium\"}), 1)) * 4 + ((sum(stigman_collection_findings{severity=\"low\"}) + sum(stigman_collection_assessments_by_severity{severity=\"low\"}) - sum(stigman_collection_assessed_by_severity{severity=\"low\"})) / clamp_min(sum(stigman_collection_assessments_by_severity{severity=\"low\"}), 1)) * 1) / 15 * 100",
          "editorMode": "code",
          "legendFormat": "",
          "range": false,
          "instant": true,
          "format": "time_series"
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "textMode": "auto",
        "wideLayout": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "#EAB839",
                "value": 0.001
              },
              {
                "color": "orange",
                "value": 10
              },
              {
                "color": "red",
                "value": 20
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          },
          "mappings": [
            {
              "type": "range",
              "options": {
                "from": 20,
                "to": 1000000000.0,
                "result": {
                  "text": "VERY HIGH RISK",
                  "color": "red",
                  "index": 0
                }
              }
            },
            {
              "type": "range",
              "options": {
                "from": 10,
                "to": 20,
                "result": {
                  "text": "HIGH RISK",
                  "color": "orange",
                  "index": 1
                }
              }
            },
            {
              "type": "range",
              "options": {
                "from": 1e-06,
                "to": 10,
                "result": {
                  "text": "MODERATE RISK",
                  "color": "#EAB839",
                  "index": 2
                }
              }
            },
            {
              "type": "range",
              "options": {
                "from": -1,
                "to": 1e-06,
                "result": {
                  "text": "LOW RISK",
                  "color": "green",
                  "index": 3
                }
              }
            }
          ]
        },
        "overrides": []
      },
      "id": 2
    },
