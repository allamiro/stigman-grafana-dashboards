{
  "uid": "stig-posture-snapshot-collection",
  "title": "STIG Posture \u2014 Review Snapshot (Per Collection)",
  "description": "Point-in-time review visuals for one collection, from recorded history.",
  "tags": [
    "stig",
    "posture",
    "snapshot",
    "collection"
  ],
  "timezone": "browser",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "liveNow": false,
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5m",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "collection",
        "label": "Collection",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "stigmanager-prometheus"
        },
        "refresh": 2,
        "multi": false,
        "includeAll": false,
        "sort": 1,
        "query": {
          "qryType": 1,
          "query": "label_values(stigman_collection_assessments, collection_name)",
          "refId": "PrometheusVariableQueryEditor-VariableQuery"
        },
        "current": {},
        "options": []
      }
    ]
  },
  "annotations": {
    "list": []
  },
  "links": [
    {
      "title": "Live (API): Management Review",
      "type": "link",
      "icon": "dashboard",
      "url": "/d/stig-posture-management",
      "targetBlank": false,
      "asDropdown": false,
      "includeVars": false,
      "keepTime": false,
      "tags": []
    },
    {
      "title": "Trends over time",
      "type": "link",
      "icon": "dashboard",
      "url": "/d/stig-posture-management-trends",
      "targetBlank": false,
      "asDropdown": false,
      "includeVars": false,
      "keepTime": true,
      "tags": []
    }
  ],
  "panels": [
    {
      "type": "piechart",
      "title": "Security posture \u2014 $collection",
      "description": "As of the end of the selected time range.",
      "gridPos": {
        "h": 10,
        "w": 9,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "stigmanager-prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "stigmanager-prometheus"
          },
          "expr": "sum(stigman_collection_results{result=\"pass\",collection_name=~\"$collection\"})",
          "editorMode": "code",
          "legendFormat": "Compliant",
          "range": false,
          "instant": true,
          "format": "time_series"
        },
        {
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "stigmanager-prometheus"
          },
          "expr": "sum(stigman_collection_results{result=\"notapplicable\",collection_name=~\"$collection\"})",
          "editorMode": "code",
          "legendFormat": "Not Applicable",
          "range": false,
          "instant": true,
          "format": "time_series"
        },
        {
          "refId": "C",
          "datasource": {
            "type": "prometheus",
            "uid": "stigmanager-prometheus"
          },
          "expr": "sum(stigman_collection_results{result=\"fail\",collection_name=~\"$collection\"})",
          "editorMode": "code",
          "legendFormat": "Open Findings",
          "range": false,
          "instant": true,
          "format": "time_series"
        },
        {
          "refId": "D",
          "datasource": {
            "type": "prometheus",
            "uid": "stigmanager-prometheus"
          },
          "expr": "sum(stigman_collection_assessments{collection_name=~\"$collection\"}) - sum(stigman_collection_assessed{collection_name=~\"$collection\"})",
          "editorMode": "code",
          "legendFormat": "Not Assessed",
          "range": false,
          "instant": true,
          "format": "time_series"
        }
      ],
      "options": {
        "pieType": "donut",
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ]
        },
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true,
          "values": [
            "value",
            "percent"
          ]
        },
        "displayLabels": [
          "percent"
        ],
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Compliant"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "green"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Not Applicable"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "blue"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Open Findings"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "red"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Not Assessed"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "orange"
                }
              }
            ]
          }
        ]
      },
      "id": 1
    },
    {
      "type": "gauge",
      "title": "Assessment coverage",
      "description": "assessed / assessments.",
      "gridPos": {
        "h": 5,
        "w": 5,
        "x": 9,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "stigmanager-prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "stigmanager-prometheus"
          },
          "expr": "sum(stigman_collection_assessed{collection_name=~\"$collection\"}) / clamp_min(sum(stigman_collection_assessments{collection_name=~\"$collection\"}), 1) * 100",
          "editorMode": "code",
          "legendFormat": "",
          "range": false,
          "instant": true,
          "format": "time_series"
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ]
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "minVizHeight": 75,
        "minVizWidth": 75,
        "sizing": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 70
              },
              {
                "color": "green",
                "value": 90
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "id": 2
    },
    {
      "type": "gauge",
      "title": "CORA risk score",
      "description": "Per-collection CORA-style score (exporter-computed, same formula as the live dashboards).",
      "gridPos": {
        "h": 5,
        "w": 5,
        "x": 14,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "stigmanager-prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "stigmanager-prometheus"
          },
          "expr": "stigman_collection_cora_percent{collection_name=~\"$collection\"}",
          "editorMode": "code",
          "legendFormat": "",
          "range": false,
          "instant": true,
          "format": "time_series"
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ]
