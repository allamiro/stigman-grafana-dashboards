    {
      "type": "stat",
      "title": "Review workflow status",
      "description": "Where this collection's reviews sit in the workflow.",
      "gridPos": {
        "h": 4,
        "w": 24,
        "x": 0,
        "y": 10
      },
      "datasource": {
        "type": "prometheus",
        "uid": "stigmanager-prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "stigmanager-prometheus"
          },
          "expr": "sum(stigman_collection_assessments{collection_name=~\"$collection\"}) - sum(stigman_collection_assessed{collection_name=~\"$collection\"})",
          "editorMode": "code",
          "legendFormat": "Unassessed",
          "range": false,
          "instant": true,
          "format": "time_series"
        },
        {
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "stigmanager-prometheus"
          },
          "expr": "sum(stigman_collection_statuses{status=\"saved\",collection_name=~\"$collection\"})",
