    {
      "type": "stat",
      "title": "Bottom line",
      "description": "Single verdict for the whole estate, from the CORA-style weighted risk score (open findings + unassessed checks, weighted CAT I x10, CAT II x4, CAT III x1). Bands: 0% Low, >0% Moderate, >=10% High, >=20% Very High. CORA-style weighted risk score computed from aggregated raw counts: p_sev = (open findings + unassessed) / assessments per severity, CORA = (p1*10 + p2*4 + p3*1) / 15. Zero-assessment severities contribute 0. Bands: 0% Low, >0% Moderate, >=10% High, >=20% Very High. Lab interpretation \u2014 verify against current DISA CORA guidance before treating as authoritative.",
      "gridPos": {
        "h": 7,
        "w": 7,
        "x": 0,
        "y": 3
      },
      "datasource": {
        "type": "yesoreyeram-infinity-datasource",
        "uid": "stigmanager-infinity"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "yesoreyeram-infinity-datasource",
            "uid": "stigmanager-infinity"
          },
          "queryType": "infinity",
          "type": "json",
          "source": "url",
          "format": "table",
          "parser": "backend",
          "url": "http://stigman:54000/api/collections/meta/metrics/summary/collection",
          "url_options": {
            "method": "GET",
            "data": ""
          },
          "root_selector": "",
          "columns": [
            {
              "selector": "metrics.findings.high",
              "text": "high",
              "type": "number"
            },
            {
              "selector": "metrics.findings.medium",
              "text": "medium",
              "type": "number"
            },
            {
              "selector": "metrics.findings.low",
              "text": "low",
              "type": "number"
            },
            {
              "selector": "metrics.assessmentsBySeverity.high",
              "text": "assessmentsHigh",
              "type": "number"
            },
            {
              "selector": "metrics.assessmentsBySeverity.medium",
              "text": "assessmentsMedium",
              "type": "number"
            },
            {
              "selector": "metrics.assessmentsBySeverity.low",
              "text": "assessmentsLow",
              "type": "number"
            },
            {
              "selector": "metrics.assessedBySeverity.high",
              "text": "assessedHigh",
              "type": "number"
            },
            {
              "selector": "metrics.assessedBySeverity.medium",
              "text": "assessedMedium",
              "type": "number"
            },
            {
              "selector": "metrics.assessedBySeverity.low",
              "text": "assessedLow",
              "type": "number"
            },
            {
              "selector": "collectionId",
              "text": "collectionId",
              "type": "string"
            }
          ],
          "filterExpression": "collectionId IN (${collections:singlequote})",
          "summarizeExpression": "((sum(assessmentsHigh) > 0 ? (sum(high) + sum(assessmentsHigh) - sum(assessedHigh)) / sum(assessmentsHigh) : 0) * 10 + (sum(assessmentsMedium) > 0 ? (sum(medium) + sum(assessmentsMedium) - sum(assessedMedium)) / sum(assessmentsMedium) : 0) * 4 + (sum(assessmentsLow) > 0 ? (sum(low) + sum(assessmentsLow) - sum(assessedLow)) / sum(assessmentsLow) : 0) * 1) / 15 * 100",
          "summarizeAlias": "Risk"
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "textMode": "auto",
        "wideLayout": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "#EAB839",
                "value": 0.001
              },
              {
                "color": "orange",
                "value": 10
              },
              {
                "color": "red",
                "value": 20
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          },
          "mappings": [
            {
              "type": "range",
              "options": {
                "from": 20,
                "to": 1000000000.0,
                "result": {
                  "text": "VERY HIGH RISK",
                  "color": "red",
                  "index": 0
                }
              }
            },
            {
              "type": "range",
              "options": {
                "from": 10,
                "to": 20,
                "result": {
                  "text": "HIGH RISK",
                  "color": "orange",
                  "index": 1
                }
              }
            },
            {
              "type": "range",
              "options": {
                "from": 1e-06,
                "to": 10,
                "result": {
                  "text": "MODERATE RISK",
                  "color": "#EAB839",
                  "index": 2
                }
              }
            },
            {
              "type": "range",
              "options": {
                "from": -1,
                "to": 1e-06,
                "result": {
                  "text": "LOW RISK",
                  "color": "green",
                  "index": 3
                }
              }
            }
          ]
        },
        "overrides": []
      },
      "id": 3
