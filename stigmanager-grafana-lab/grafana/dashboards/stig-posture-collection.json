{
  "uid": "stig-posture-collection",
  "title": "STIG Posture \u2014 Per Collection",
  "description": "Security posture for a single STIG Manager collection, fed by the STIG Manager API via the Infinity datasource (service account: nexus-reporter, read-only).",
  "tags": [
    "stig",
    "posture",
    "collection"
  ],
  "timezone": "browser",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "liveNow": false,
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5m",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "collection",
        "label": "Collection",
        "type": "query",
        "datasource": {
          "type": "yesoreyeram-infinity-datasource",
          "uid": "stigmanager-infinity"
        },
        "refresh": 1,
        "multi": false,
        "includeAll": false,
        "sort": 1,
        "query": {
          "queryType": "infinity",
          "query": "",
          "infinityQuery": {
            "refId": "variable",
            "queryType": "infinity",
            "type": "json",
            "source": "url",
            "format": "table",
            "parser": "backend",
            "url": "http://stigman:54000/api/collections",
