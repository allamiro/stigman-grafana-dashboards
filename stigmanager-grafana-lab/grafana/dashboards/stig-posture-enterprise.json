    {
      "type": "gauge",
      "title": "Enterprise CORA risk score",
      "description": "Aggregated-first enterprise score: raw severity counts are summed across selected collections, then the CORA formula is applied. CORA-style weighted risk score computed from aggregated raw counts: p_sev = (open findings + unassessed) / assessments per severity, CORA = (p1*10 + p2*4 + p3*1) / 15. Zero-assessment severities contribute 0. Bands: 0% Low, >0% Moderate, >=10% High, >=20% Very High. Lab interpretation \u2014 verify against current DISA CORA guidance before treating as authoritative.",
      "gridPos": {
        "h": 9,
        "w": 6,
        "x": 18,
        "y": 13
      },
      "datasource": {
        "type": "yesoreyeram-infinity-datasource",
        "uid": "stigmanager-infinity"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "yesoreyeram-infinity-datasource",
            "uid": "stigmanager-infinity"
          },
          "queryType": "infinity",
          "type": "json",
          "source": "url",
          "format": "table",
          "parser": "backend",
          "url": "http://stigman:54000/api/collections/meta/metrics/summary/collection",
          "url_options": {
            "method": "GET",
            "data": ""
          },
          "root_selector": "",
          "columns": [
            {
              "selector": "collectionId",
              "text": "collectionId",
              "type": "string"
            },
            {
              "selector": "metrics.findings.high",
              "text": "high",
              "type": "number"
            },
            {
              "selector": "metrics.findings.medium",
              "text": "medium",
              "type": "number"
            },
            {
              "selector": "metrics.findings.low",
              "text": "low",
              "type": "number"
            },
            {
              "selector": "metrics.assessmentsBySeverity.high",
              "text": "assessmentsHigh",
              "type": "number"
            },
            {
              "selector": "metrics.assessmentsBySeverity.medium",
              "text": "assessmentsMedium",
              "type": "number"
            },
            {
              "selector": "metrics.assessmentsBySeverity.low",
              "text": "assessmentsLow",
              "type": "number"
            },
            {
              "selector": "metrics.assessedBySeverity.high",
              "text": "assessedHigh",
              "type": "number"
            },
            {
              "selector": "metrics.assessedBySeverity.medium",
              "text": "assessedMedium",
              "type": "number"
            },
            {
              "selector": "metrics.assessedBySeverity.low",
              "text": "assessedLow",
              "type": "number"
            }
          ],
          "filterExpression": "collectionId IN (${collections:singlequote})",
          "summarizeExpression": "((sum(assessmentsHigh) > 0 ? (sum(high) + sum(assessmentsHigh) - sum(assessedHigh)) / sum(assessmentsHigh) : 0) * 10 + (sum(assessmentsMedium) > 0 ? (sum(medium) + sum(assessmentsMedium) - sum(assessedMedium)) / sum(assessmentsMedium) : 0) * 4 + (sum(assessmentsLow) > 0 ? (sum(low) + sum(assessmentsLow) - sum(assessedLow)) / sum(assessmentsLow) : 0) * 1) / 15 * 100",
          "summarizeAlias": "Enterprise CORA"
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ]
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "minVizHeight": 75,
        "minVizWidth": 75,
        "sizing": "auto"
