{
  "uid": "stig-posture-collection-trends",
  "title": "STIG Posture \u2014 Per Collection (Trends)",
  "description": "Historical posture trends for a single collection.",
  "tags": [
    "stig",
    "posture",
    "collection",
    "trends"
  ],
  "timezone": "browser",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "liveNow": false,
  "schemaVersion": 39,
  "version": 1,
  "refresh": "1m",
  "time": {
    "from": "now-24h",
    "to": "now"
