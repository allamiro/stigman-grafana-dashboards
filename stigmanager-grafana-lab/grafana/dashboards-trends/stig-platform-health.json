  "description": "Health of the exporter \u2192 STIG Manager scrape pipeline.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "type": "text",
      "title": "",
      "gridPos": {
        "h": 3,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "options": {
        "mode": "markdown",
        "content": "## STIG Manager Platform Health\nIs the metrics pipeline itself alive? This watches the **exporter \u2192 STIG Manager/Keycloak** scrape, not posture. If `Scrape status` is DOWN or the last success is stale, trends everywhere else stop updating.\n\n*Datasource: Prometheus. Add an alert on `stigman_scrape_success == 0`.*"
      },
      "id": 1
    },
    {
      "type": "stat",
      "title": "Scrape status",
      "description": "1 = last scrape of the STIG Manager API succeeded.",
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 0,
        "y": 3
      },
      "datasource": {
        "type": "prometheus",
        "uid": "stigmanager-prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "stigmanager-prometheus"
          },
          "expr": "min(stigman_scrape_success)",
          "editorMode": "code",
          "legendFormat": "__auto",
          "range": true,
          "instant": false
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "textMode": "auto",
        "wideLayout": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "DOWN",
                  "color": "red"
                },
                "1": {
                  "text": "UP",
                  "color": "green"
                }
              }
            }
          ]
        },
        "overrides": []
      },
      "id": 2
    },
    {
      "type": "stat",
      "title": "Time since last success",
      "description": "Seconds since the last successful scrape. Rising = pipeline stalled.",
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 6,
        "y": 3
      },
      "datasource": {
        "type": "prometheus",
        "uid": "stigmanager-prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "stigmanager-prometheus"
          },
          "expr": "time() - max(timestamp(stigman_scrape_success == 1))",
          "editorMode": "code",
