    {
      "type": "stat",
      "title": "Bottom line",
      "description": "Latest recorded CORA-style risk verdict.",
      "gridPos": {
        "h": 6,
        "w": 7,
        "x": 0,
        "y": 3
      },
      "datasource": {
        "type": "prometheus",
        "uid": "stigmanager-prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "stigmanager-prometheus"
          },
          "expr": "(((sum(stigman_collection_findings{severity=\"high\",collection_name=~\"$collection\"}) + sum(stigman_collection_assessments_by_severity{severity=\"high\",collection_name=~\"$collection\"}) - sum(stigman_collection_assessed_by_severity{severity=\"high\",collection_name=~\"$collection\"})) / clamp_min(sum(stigman_collection_assessments_by_severity{severity=\"high\",collection_name=~\"$collection\"}), 1)) * 10 + ((sum(stigman_collection_findings{severity=\"medium\",collection_name=~\"$collection\"}) + sum(stigman_collection_assessments_by_severity{severity=\"medium\",collection_name=~\"$collection\"}) - sum(stigman_collection_assessed_by_severity{severity=\"medium\",collection_name=~\"$collection\"})) / clamp_min(sum(stigman_collection_assessments_by_severity{severity=\"medium\",collection_name=~\"$collection\"}), 1)) * 4 + ((sum(stigman_collection_findings{severity=\"low\",collection_name=~\"$collection\"}) + sum(stigman_collection_assessments_by_severity{severity=\"low\",collection_name=~\"$collection\"}) - sum(stigman_collection_assessed_by_severity{severity=\"low\",collection_name=~\"$collection\"})) / clamp_min(sum(stigman_collection_assessments_by_severity{severity=\"low\",collection_name=~\"$collection\"}), 1)) * 1) / 15 * 100",
          "editorMode": "code",
          "legendFormat": "__auto",
          "range": true,
          "instant": false
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "textMode": "auto",
        "wideLayout": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
