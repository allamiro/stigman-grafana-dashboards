# Copy to .env and adjust. Never commit the populated .env.
# Generate strong secrets with:  openssl rand -hex 32
# Or run:  ./scripts/generate-env.sh   (creates .env with random secrets)

# --- Keycloak admin console (http://localhost:8180) ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=KeycloakAdmin123!

# --- Keycloak database (PostgreSQL, not exposed on the host) ---
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=KeycloakDB123!

# --- STIG Manager database (MySQL, not exposed on the host) ---
STIGMAN_DB_NAME=stigman
STIGMAN_DB_USER=stigman
STIGMAN_DB_PASSWORD=StigmanDB123!

# --- Lab administrator (Keycloak user with STIG Manager admin privileges) ---
STIGMAN_ADMIN_USERNAME=stigadmin
STIGMAN_ADMIN_PASSWORD=StigAdmin123!
STIGMAN_ADMIN_EMAIL=stigadmin@example.local

# --- Grafana local admin (http://localhost:3200) ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=GrafanaAdmin123!

# --- Reporting service account (client-credentials; read-only) ---
NEXUS_REPORTER_CLIENT_ID=nexus-reporter
NEXUS_REPORTER_CLIENT_SECRET=replace-with-a-long-secret

# --- Grafana browser SSO client (confidential) ---
GRAFANA_OIDC_CLIENT_ID=grafana
GRAFANA_OIDC_CLIENT_SECRET=replace-with-another-long-secret
