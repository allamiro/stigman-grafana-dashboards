# =====================================================================
# STIG Manager Prometheus exporter — environment file (example)
# =====================================================================
# Copy to .env (or /etc/stigman-exporter.env) and fill in the secret.
# Every variable the exporter reads is listed below, with its default.
#
#   docker run --env-file .env -p 9633:9633 stigman-exporter:1.1.0
#   # or, for systemd:  EnvironmentFile=/etc/stigman-exporter.env
#
# Inside the lab's docker-compose stack these are injected automatically
# from the top-level .env — this file is for running the exporter
# STANDALONE (docker run / systemd / another host).
# Never commit the populated file: it holds OIDC_CLIENT_SECRET.

# --- Required ---------------------------------------------------------

# STIG Manager API base URL (include the /api suffix).
#   compose (container-to-container): http://stigman:54000/api
#   standalone against the lab's published port: http://localhost:54000/api
#   from a container reaching the host: http://host.docker.internal:54000/api
STIGMAN_API_URL=http://localhost:54000/api

# Keycloak OIDC token endpoint for the client-credentials grant.
#   compose: http://keycloak:8080/realms/stigman/protocol/openid-connect/token
#   standalone: http://localhost:8180/realms/stigman/protocol/openid-connect/token
KEYCLOAK_TOKEN_URL=http://localhost:8180/realms/stigman/protocol/openid-connect/token

# Secret for the read-only nexus-reporter service account.
# In the lab this is NEXUS_REPORTER_CLIENT_SECRET from the top-level .env.
# Generate one with:  openssl rand -hex 32
OIDC_CLIENT_SECRET=replace-with-the-nexus-reporter-secret

# --- Optional (defaults shown) ---------------------------------------

# OIDC client id of the reporting service account.
OIDC_CLIENT_ID=nexus-reporter

# Port the /metrics endpoint listens on.
EXPORTER_PORT=9633

# Per-request timeout, seconds, for both the Keycloak and API calls.
REQUEST_TIMEOUT=15

# --- TLS verification -------------------------------------------------
# Only relevant when the URLs above are https:// . Accepted values for
# every *_VERIFY_TLS var: "true", "false", or a path to a CA-bundle file.

# Global default applied to BOTH the Keycloak and STIG Manager calls.
#   true                       verify against the system trust store (default)
#   /certs/internal-ca.pem     trust an internal/private CA bundle
#   false                      disable verification (INSECURE — lab/self-signed
#                              only, never production; logs a startup warning)
STIGMAN_VERIFY_TLS=true

# Optional per-endpoint overrides. Set these when Keycloak and STIG Manager
# differ — a different CA chain on each, OR you want to disable verification
# for just one of them. Each accepts the SAME values as STIGMAN_VERIFY_TLS
# ("true", "false", or a CA-bundle path) and falls back to it when unset.
#
# Trust a different CA per endpoint:
# KEYCLOAK_VERIFY_TLS=/certs/keycloak-ca.pem
# STIGMAN_API_VERIFY_TLS=/certs/stigman-ca.pem
#
# Disable verification for just one endpoint (INSECURE — lab/self-signed only):
# KEYCLOAK_VERIFY_TLS=false
# STIGMAN_API_VERIFY_TLS=false
#
# (To disable BOTH at once, just set STIGMAN_VERIFY_TLS=false above.)
