{
  "realm": "stigman",
  "enabled": true,
  "displayName": "STIG Manager Lab",
  "registrationAllowed": false,
  "resetPasswordAllowed": false,
  "rememberMe": true,
  "bruteForceProtected": true,
  "sslRequired": "external",
  "accessTokenLifespan": 600,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "roles": {
    "realm": [
      {
        "name": "admin",
        "description": "STIG Manager privilege: Application Manager (maps via realm_access.roles)"
      },
      {
        "name": "create_collection",
        "description": "STIG Manager privilege: may create Collections"
      },
      {
        "name": "grafana_admin",
        "description": "Mapped to Grafana GrafanaAdmin via role_attribute_path"
      }
    ]
  },
  "defaultDefaultClientScopes": ["roles", "profile", "email", "web-origins", "acr"],
  "defaultOptionalClientScopes": ["offline_access"],
  "clientScopes": [
    {
      "name": "profile",
      "description": "OpenID Connect built-in scope: profile",
      "protocol": "openid-connect",
      "attributes": { "include.in.token.scope": "true", "display.on.consent.screen": "false" },
      "protocolMappers": [
        {
          "name": "username",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "username",
            "claim.name": "preferred_username",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "full name",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-full-name-mapper",
          "consentRequired": false,
          "config": {
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "given name",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "firstName",
            "claim.name": "given_name",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "family name",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "lastName",
            "claim.name": "family_name",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "name": "email",
      "description": "OpenID Connect built-in scope: email",
      "protocol": "openid-connect",
      "attributes": { "include.in.token.scope": "true", "display.on.consent.screen": "false" },
      "protocolMappers": [
        {
          "name": "email",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "email",
            "claim.name": "email",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "email verified",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "emailVerified",
            "claim.name": "email_verified",
            "jsonType.label": "boolean",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "name": "roles",
      "description": "OpenID Connect built-in scope: roles",
      "protocol": "openid-connect",
      "attributes": { "include.in.token.scope": "false", "display.on.consent.screen": "false" },
      "protocolMappers": [
        {
          "name": "realm roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "foo",
            "multivalued": "true",
            "claim.name": "realm_access.roles",
            "jsonType.label": "String",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "userinfo.token.claim": "false"
          }
        },
        {
          "name": "client roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-client-role-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "foo",
            "multivalued": "true",
            "claim.name": "resource_access.${client_id}.roles",
            "jsonType.label": "String",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "userinfo.token.claim": "false"
          }
        },
        {
          "name": "audience resolve",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-resolve-mapper",
          "consentRequired": false,
          "config": {}
        }
      ]
    },
    {
      "name": "web-origins",
      "description": "OpenID Connect built-in scope: web-origins",
      "protocol": "openid-connect",
      "attributes": { "include.in.token.scope": "false", "display.on.consent.screen": "false" },
      "protocolMappers": [
        {
          "name": "allowed web origins",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-allowed-origins-mapper",
          "consentRequired": false,
          "config": {}
        }
      ]
    },
    {
      "name": "acr",
      "description": "OpenID Connect built-in scope: acr",
      "protocol": "openid-connect",
      "attributes": { "include.in.token.scope": "false", "display.on.consent.screen": "false" },
      "protocolMappers": [
        {
          "name": "acr loa level",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-acr-mapper",
          "consentRequired": false,
          "config": {
            "id.token.claim": "true",
            "access.token.claim": "true"
          }
        }
      ]
    },
    {
      "name": "stig-manager:collection",
      "description": "Write access to STIG Manager Collection endpoints",
      "protocol": "openid-connect",
      "attributes": { "include.in.token.scope": "true", "display.on.consent.screen": "false" }
    },
    {
      "name": "stig-manager:collection:read",
      "description": "Read access to STIG Manager Collection endpoints",
      "protocol": "openid-connect",
      "attributes": { "include.in.token.scope": "true", "display.on.consent.screen": "false" }
    },
    {
      "name": "stig-manager:stig",
      "description": "Write access to STIG Manager STIG endpoints",
      "protocol": "openid-connect",
      "attributes": { "include.in.token.scope": "true", "display.on.consent.screen": "false" }
    },
    {
      "name": "stig-manager:stig:read",
      "description": "Read access to STIG Manager STIG endpoints",
      "protocol": "openid-connect",
      "attributes": { "include.in.token.scope": "true", "display.on.consent.screen": "false" }
    },
    {
      "name": "stig-manager:user",
      "description": "Write access to STIG Manager User endpoints",
      "protocol": "openid-connect",
      "attributes": { "include.in.token.scope": "true", "display.on.consent.screen": "false" }
    },
    {
      "name": "stig-manager:user:read",
      "description": "Read access to STIG Manager User endpoints",
      "protocol": "openid-connect",
      "attributes": { "include.in.token.scope": "true", "display.on.consent.screen": "false" }
    },
    {
      "name": "stig-manager:op",
      "description": "Write access to STIG Manager Operation endpoints",
      "protocol": "openid-connect",
      "attributes": { "include.in.token.scope": "true", "display.on.consent.screen": "false" }
    },
    {
      "name": "stig-manager:op:read",
      "description": "Read access to STIG Manager Operation endpoints",
      "protocol": "openid-connect",
      "attributes": { "include.in.token.scope": "true", "display.on.consent.screen": "false" }
    },
    {
      "name": "stig-manager-audience",
      "description": "Adds aud=stig-manager so the API can enforce STIGMAN_JWT_AUD_VALUE",
      "protocol": "openid-connect",
      "attributes": { "include.in.token.scope": "false", "display.on.consent.screen": "false" },
      "protocolMappers": [
        {
          "name": "stig-manager-audience-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.custom.audience": "stig-manager",
            "access.token.claim": "true",
            "id.token.claim": "false"
          }
        }
      ]
    }
  ],
  "clients": [
    {
      "clientId": "stig-manager",
      "name": "STIG Manager web client",
      "description": "Public browser client used by the STIG Manager UI (Authorization Code + PKCE)",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "rootUrl": "http://localhost:54000/",
      "redirectUris": ["http://localhost:54000/*"],
      "webOrigins": ["http://localhost:54000"],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:54000/*"
      },
      "fullScopeAllowed": true,
      "defaultClientScopes": [
        "web-origins",
        "acr",
        "roles",
        "profile",
        "email",
        "stig-manager-audience",
        "stig-manager:collection",
        "stig-manager:collection:read",
        "stig-manager:stig",
        "stig-manager:stig:read",
        "stig-manager:user",
        "stig-manager:user:read",
        "stig-manager:op",
        "stig-manager:op:read"
      ],
      "optionalClientScopes": ["offline_access", "microprofile-jwt"]
    },
    {
      "clientId": "grafana",
      "name": "Grafana SSO client",
      "description": "Confidential client for Grafana Generic OAuth browser login",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "${GRAFANA_OIDC_CLIENT_SECRET}",
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "rootUrl": "http://localhost:3200/",
      "redirectUris": ["http://localhost:3200/login/generic_oauth"],
      "webOrigins": ["http://localhost:3200"],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:3200/*"
      },
      "fullScopeAllowed": true,
      "defaultClientScopes": ["web-origins", "acr", "roles", "profile", "email"],
      "optionalClientScopes": [],
      "protocolMappers": [
        {
          "name": "realm-roles-for-grafana",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "claim.name": "realm_access.roles",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "nexus-reporter",
      "name": "Grafana reporting service account",
      "description": "Confidential client-credentials client used by the Grafana Infinity datasource. Read-only STIG Manager scopes only.",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "${NEXUS_REPORTER_CLIENT_SECRET}",
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "redirectUris": [],
      "webOrigins": [],
      "fullScopeAllowed": false,
      "defaultClientScopes": [
        "profile",
        "stig-manager-audience",
        "stig-manager:collection:read",
        "stig-manager:stig:read",
        "stig-manager:user:read",
        "stig-manager:op:read"
      ],
      "optionalClientScopes": []
    }
  ],
  "users": [
    {
      "username": "stigadmin",
      "enabled": true,
      "emailVerified": true,
      "firstName": "STIG",
      "lastName": "Admin",
      "email": "stigadmin@example.local",
      "credentials": [
        {
          "type": "password",
          "value": "${STIGMAN_ADMIN_PASSWORD}",
          "temporary": false
        }
      ],
      "realmRoles": ["default-roles-stigman", "admin", "create_collection", "grafana_admin"]
    }
  ]
}
